# Local development uses SQLite automatically when Turso env vars are empty.
DATABASE_MODE=sqlite
SQLITE_DB_PATH=./data/dashboard-man1.sqlite

# Production Turso/libSQL database.
# Create these with Turso CLI, then set them in your deployment provider.
# Set DATABASE_MODE=turso in production.
TURSO_DATABASE_URL=libsql://your-database-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Better Auth.
BETTER_AUTH_URL=http://localhost:3100
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3100
ADMIN_EMAILS=
CRON_SECRET=replace-with-a-long-random-secret

# Upstream integration. Keep credentials server-side and leave them empty here.
EMIS_PUBLIC_URL_API=https://api-emis.kemenag.go.id/v1/
EMIS_PUBLIC_KEY=
EMIS_PRIVATE_KEY=
EMIS_NSM=131118010001
EMIS_AUTH_MODE=partner-login
EMIS_AUTH_PUBLIC_HEADER=
EMIS_AUTH_PRIVATE_HEADER=
EMIS_ENDPOINT_PARTNER_LOGIN=accounts/partners-login
EMIS_PARTNER_LOGIN_FORMAT=json
EMIS_PARTNER_PUBLIC_FIELD=public_key
EMIS_PARTNER_PRIVATE_FIELD=private_key
EMIS_PARTNER_TOKEN_PATH=results.token
EMIS_ENDPOINT_STUDENT_SUMMARY=
EMIS_FIELD_STUDENTS_TOTAL=
EMIS_FIELD_GRADE_10=
EMIS_FIELD_GRADE_11=
EMIS_FIELD_GRADE_12=
EMIS_FIELD_MALE=
EMIS_FIELD_FEMALE=
EMIS_FIELD_STUDY_GROUPS_TOTAL=
EMIS_SYNC_PERIOD=2025/2026 Genap
EMIS_SYNC_SCHOOL_YEAR=2025/2026
EMIS_SYNC_SEMESTER=Genap

SIMPEG_PUBLIC_URL_API=https://api.kemenag.go.id/v1
SIMPEG_PUBLIC_EMAIL=
SIMPEG_PUBLIC_PASSWORD=
SIMPEG_NSM=131118010001
SIMPEG_NPSN=10816233
SIMPEG_UNIT_NAME=MAN 1 Lampung Selatan
SIMPEG_PAGE_PARAM=page
SIMPEG_SIZE_PARAM=size

# Database mitra lokal/LAN (gunakan akun SELECT-only, jangan root).
MIRROR_DB_HOST=
MIRROR_DB_PORT=3306
MIRROR_DB_DATABASE=datalampung
MIRROR_DB_USERNAME=dashboard_reader
MIRROR_DB_PASSWORD=
MIRROR_DB_SSL=disabled
MIRROR_DB_NSM=131118010001
MIRROR_DB_NPSN=10816233
MIRROR_SYNC_PERIOD=
MIRROR_SYNC_SCHOOL_YEAR=Belum dipetakan
MIRROR_SYNC_SEMESTER=Belum dipetakan

# Validasi publik GIS Madrasah Kemenag.
GIS_MADRASAH_API_URL=https://madrasah.kemenag.go.id/api-gis/api
GIS_MADRASAH_ID=14343

# API agregat dari website resmi madrasah. Endpoint saat ini masih perlu dibuat.
MAN1_WEBSITE_API_URL=https://man1lamsel.sch.id/api/v1/dashboard/summary
MAN1_WEBSITE_API_KEY=
MAN1_WEBSITE_SYNC_ENABLED=false

# OpenAI Assistant (server-side only).
# Put the real key in .env.local or your hosting environment variables.
# Never expose this value with NEXT_PUBLIC_.
OPENAI_API_KEY=
OPENAI_MODEL=
